{
  "$comment": "REPO-SPECIFIC config for the HDS monorepo pilot of the token-usage auditor. Copy this file per repo and edit only these values; never edit verify-tokens.mjs. 'allowlist' holds extra known tokens that use the audited prefix but are NOT defined in the tokens package (e.g. internal --hds-var-* runtime variables collected from packages/components/src).",
  "tokensPackage": "@hashicorp/design-system-tokens",
  "tokensCssPath": "dist/products/css/tokens.css",
  "tokensCssOverride": null,
  "tokensResolveFrom": [ "packages/components" ],
  "prefix": "--hds-",
  "roots": [
    "packages/components/src",
    "showcase/app",
    "showcase/tests",
    "website/app",
    "website/docs"
  ],
  "extensions": [ "scss", "css", "gts", "hbs", "ts", "js" ],
  "excludeGlobs": [
    "**/dist/**",
    "**/node_modules/**",
    "**/.git/**",
    "**/*.map",
    "**/*.md",
    "showcase/public/assets/**"
  ],
  "reportSubdir": "hds",
  "reportGroups": [
    "packages/tokens",
    "packages/components",
    "packages/flight-icons",
    "showcase",
    "website"
  ],
  "allowlist": [
    "--hds-var-app-footer-status-icon-color",
