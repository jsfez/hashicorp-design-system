{
  "product": {
    "vagrant": {
      "brand": {
        "color": {
          "$type": "color",
          "$value": "{core.color.vagrant-brand}",
          "group": "branding"
        }
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{core.color.vagrant-500}",
          "group": "branding"
        }
      },
      "surface": {
        "color": {
          "$type": "color",
          "$value": "{core.color.vagrant-50}",
          "group": "branding"
        }
      },
      "border": {
        "color": {
          "$type": "color",
          "$value": "{core.color.vagrant-100}",
          "group": "branding"
        }
      },
      "gradient": {
        "color": {
          "primary": {
            "start": {
              "$type": "color",
              "$value": "{core.color.vagrant-300}",
              "group": "branding"
            },
            "stop": {
              "$type": "color",
              "$value": "{core.color.vagrant-400}",
              "group": "branding"
            }
          },
          "faint": {
            "start": {
              "$type": "color",
              "$value": "#f4faff",
              "group": "branding",
              "comment": "this is the 'vagrant-50' value at 25% opacity on white"
            },
            "stop": {
              "$type": "color",
              "$value": "{core.color.vagrant-50}",
              "group": "branding"
            }
          }
        }
      }
    }
  }
}