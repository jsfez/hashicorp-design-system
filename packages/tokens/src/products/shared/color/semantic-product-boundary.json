{
  "product": {
    "boundary": {
      "brand": {
        "color": {
          "$type": "color",
          "$value": "{core.color.boundary-brand}",
          "group": "branding"
        }
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{core.color.boundary-500}",
          "group": "branding"
        }
      },
      "surface": {
        "color": {
          "$type": "color",
          "$value": "{core.color.boundary-50}",
          "group": "branding"
        }
      },
      "border": {
        "color": {
          "$type": "color",
          "$value": "{core.color.boundary-100}",
          "group": "branding"
        }
      },
      "gradient": {
        "color": {
          "primary": {
            "start": {
              "$type": "color",
              "$value": "{core.color.boundary-300}",
              "group": "branding"
            },
            "stop": {
              "$type": "color",
              "$value": "{core.color.boundary-400}",
              "group": "branding"
            }
          },
          "faint": {
            "start": {
              "$type": "color",
              "$value": "#fffafa",
              "group": "branding",
              "comment": "this is the 'boundary-50' value at 25% opacity on white"
            },
            "stop": {
              "$type": "color",
              "$value": "{core.color.boundary-50}",
              "group": "branding"
            }
          }
        }
      }
    }
  }
}