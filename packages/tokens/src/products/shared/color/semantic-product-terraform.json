{
  "product": {
    "terraform": {
      "brand": {
        "color": {
          "$type": "color",
          "$value": "{core.color.terraform-brand}",
          "group": "branding"
        },
        "color-on-dark": {
          "$type": "color",
          "$value": "#a067da",
          "group": "branding",
          "comment": "this is an alternative brand color meant to be used on dark backgrounds"
        }
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{core.color.terraform-500}",
          "group": "branding"
        }
      },
      "surface": {
        "color": {
          "$type": "color",
          "$value": "{core.color.terraform-50}",
          "group": "branding"
        }
      },
      "border": {
        "color": {
          "$type": "color",
          "$value": "{core.color.terraform-100}",
          "group": "branding"
        }
      },
      "gradient": {
        "color": {
          "primary": {
            "start": {
              "$type": "color",
              "$value": "{core.color.terraform-300}",
              "group": "branding"
            },
            "stop": {
              "$type": "color",
              "$value": "{core.color.terraform-400}",
              "group": "branding"
            }
          },
          "faint": {
            "start": {
              "$type": "color",
              "$value": "#fcfaff",
              "group": "branding",
              "comment": "this is the 'terraform-50' value at 25% opacity on white"
            },
            "stop": {
              "$type": "color",
              "$value": "{core.color.terraform-50}",
              "group": "branding"
            }
          }
        }
      }
    }
  }
}