{
  "product": {
    "vault": {
      "brand": {
        "color": {
          "$type": "color",
          "$value": "{core.color.vault-brand}",
          "group": "branding"
        },
        "color-alt": {
          "$type": "color",
          "$value": "#000",
          "group": "branding",
          "$modes": {
            "default": "#000",
            "cds-g0": "#000",
            "cds-g10": "#000",
            "cds-g90": "#FFF",
            "cds-g100": "#FFF"
          },
          "comment": "this is a special “alternative” color, used as an exception in some contexts where the normal “brand” color for Vault would not work"
        }
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{core.color.vault-500}",
          "group": "branding"
        }
      },
      "surface": {
        "color": {
          "$type": "color",
          "$value": "{core.color.vault-50}",
          "group": "branding"
        }
      },
      "border": {
        "color": {
          "$type": "color",
          "$value": "{core.color.vault-100}",
          "group": "branding"
        }
      },
      "gradient": {
        "color": {
          "primary": {
            "start": {
              "$type": "color",
              "$value": "{core.color.vault-100}",
              "group": "branding"
            },
            "stop": {
              "$type": "color",
              "$value": "{core.color.vault-200}",
              "group": "branding"
            }
          },
          "faint": {
            "start": {
              "$type": "color",
              "$value": "#fffdf2",
              "group": "branding",
              "comment": "this is the 'vault-50' value at 25% opacity on white"
            },
            "stop": {
              "$type": "color",
              "$value": "{core.color.vault-50}",
              "group": "branding"
            }
          }
        }
      }
    }
  }
}