{
  "modal": {
    "header": {
      "foreground": {
        "color": {
          "warning": {
            "$type": "color",
            "$value": "{foreground.color.warning-on-surface}",
            "$modes": {
              "default": "{foreground.color.warning-on-surface}",
              "cds-g0": "{carbon.themes.white.textPrimary}",
              "cds-g10": "{carbon.themes.g10.textPrimary}",
              "cds-g90": "{carbon.themes.g90.textPrimary}",
              "cds-g100": "{carbon.themes.g100.textPrimary}"
            }
          },
          "critical": {
            "$type": "color",
            "$value": "{foreground.color.critical-on-surface}",
            "$modes": {
              "default": "{foreground.color.critical-on-surface}",
              "cds-g0": "{carbon.themes.white.textPrimary}",
              "cds-g10": "{carbon.themes.g10.textPrimary}",
              "cds-g90": "{carbon.themes.g90.textPrimary}",
              "cds-g100": "{carbon.themes.g100.textPrimary}"
            }
          }
        }
      },
      "surface": {
        "color": {
          "warning": {
            "$type": "color",
            "$value": "{surface.color.warning}",
            "$modes": {
              "default": "{surface.color.warning}",
              "cds-g0": "{surface.color.faint}",
              "cds-g10": "{surface.color.faint}",
              "cds-g90": "{surface.color.faint}",
              "cds-g100": "{surface.color.faint}"
            }
          },
          "critical": {
            "$type": "color",
            "$value": "{surface.color.critical}",
            "$modes": {
              "default": "{surface.color.critical}",
              "cds-g0": "{surface.color.faint}",
              "cds-g10": "{surface.color.faint}",
              "cds-g90": "{surface.color.faint}",
              "cds-g100": "{surface.color.faint}"
            }
          }
        }
      },
      "border": {
        "color": {
          "warning": {
            "$type": "color",
            "$value": "{border.color.warning}",
            "$modes": {
              "default": "{border.color.warning}",
              "cds-g0": "transparent",
              "cds-g10": "transparent",
              "cds-g90": "transparent",
              "cds-g100": "transparent"
            }
          },
          "critical": {
            "$type": "color",
            "$value": "{border.color.critical}",
            "$modes": {
              "default": "{border.color.critical}",
              "cds-g0": "transparent",
              "cds-g10": "transparent",
              "cds-g90": "transparent",
              "cds-g100": "transparent"
            }
          }
        }
      },
      "tagline": {
        "color": {
          "warning": {
            "$type": "color",
            "$value": "{foreground.color.warning-on-surface}",
            "$modes": {
              "default": "{foreground.color.warning-on-surface}",
              "cds-g0": "{carbon.themes.white.textSecondary}",
              "cds-g10": "{carbon.themes.g10.textSecondary}",
              "cds-g90": "{carbon.themes.g90.textSecondary}",
              "cds-g100": "{carbon.themes.g100.textSecondary}"
            }
          },
          "critical": {
            "$type": "color",
            "$value": "{foreground.color.critical-on-surface}",
            "$modes": {
              "default": "{foreground.color.critical-on-surface}",
              "cds-g0": "{carbon.themes.white.textSecondary}",
              "cds-g10": "{carbon.themes.g10.textSecondary}",
              "cds-g90": "{carbon.themes.g90.textSecondary}",
              "cds-g100": "{carbon.themes.g100.textSecondary}"
            }
          }
        }
      }
