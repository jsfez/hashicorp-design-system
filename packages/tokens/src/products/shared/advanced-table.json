{
  "advanced-table": {
    "cell": {
      "padding": {
        "horizontal": {
          "short": {
            "$type": "dimension",
            "$value": "{table.cell.padding.horizontal.short}"
          },
          "medium": {
            "$type": "dimension",
            "$value": "{table.cell.padding.horizontal.medium}"
          },
          "tall": {
            "$type": "dimension",
            "$value": "{table.cell.padding.horizontal.tall}"
          }
        },
        "vertical": {
          "short": {
            "$type": "dimension",
            "$value": "{table.cell.padding.vertical.short}"
          },
          "medium": {
            "$type": "dimension",
            "$value": "{table.cell.padding.vertical.medium}"
          },
          "tall": {
            "$type": "dimension",
            "$value": "{table.cell.padding.vertical.tall}"
          }
        }
      },
      "surface": {
        "color": {
          "default": {
            "$type": "color",
            "$value": "{surface.color.primary}"
          },
          "hover": {
            "$type": "color",
            "$value": "{surface.color.primary}",
            "$modes": {
              "default": "{surface.color.primary}",
              "cds-g0": "#E0E0E0",
              "cds-g10": "#F1F1F1",
              "cds-g90": "#474747",
              "cds-g100": "#373737"
            },
            "comment": "the carbon hover colors have alpha values so when a column is pinned + hovered, you can see the content behind the pinned column. These are the closest match to the carbon hover colors without alpha values."
          },
          "striped": {
            "default": {
              "$type": "color",
              "$value": "{table.cell.surface.color.striped.default}"
            },
            "hover": {
              "$type": "color",
              "$value": "{surface.color.primary}",
              "$modes": {
                "default": "{surface.color.primary}",
                "cds-g0": "#E8E8E8",
                "cds-g10": "#E8E8E8",
                "cds-g90": "#474747",
                "cds-g100": "#373737"
              },
              "comment": "the carbon hover colors have alpha values so when a column is pinned + hovered, you can see the content behind the pinned column. These are the closest match to the carbon hover colors without alpha values."
            }
          },
          "selected": {
            "default": {
              "$type": "color",
              "$value": "{table.cell.surface.color.selected.default}"
            },
            "hover": {
              "$type": "color",
              "$value": "{table.cell.surface.color.selected.hover}"
            }
          },
          "parent": {
            "hover": {
              "$type": "color",
              "$value": "{surface.color.primary}",
              "$modes": {
                "default": "{surface.color.primary}",
                "cds-g0": "{carbon.themes.white.backgroundHover}",
                "cds-g10": "{carbon.themes.g10.backgroundHover}",
                "cds-g90": "{carbon.themes.g90.backgroundHover}",
                "cds-g100": "{carbon.themes.g100.backgroundHover}"
              }
            }
          },
          "nested": {
            "default": {
              "$type": "color",
              "$value": "{surface.color.faint}",
              "$modes": {
                "default": "{surface.color.faint}",
                "cds-g0": "{carbon.themes.white.layerAccent01}",
                "cds-g10": "{carbon.themes.g10.layerAccent01}",
                "cds-g90": "{carbon.themes.g90.layerAccent01}",
                "cds-g100": "{carbon.themes.g100.layerAccent01}"
              }
            },
            "hover": {
              "$type": "color",
              "$value": "{surface.color.faint}",
              "$modes": {
                "default": "{surface.color.faint}",
                "cds-g0": "{carbon.themes.white.backgroundHover}",
                "cds-g10": "{carbon.themes.g10.backgroundHover}",
                "cds-g90": "{carbon.themes.g90.backgroundHover}",
                "cds-g100": "{carbon.themes.g100.backgroundHover}"
              }
            }
          }
        }
      },
      "foreground": {
        "color": {
          "default": {
            "$type": "color",
            "$value": "{table.cell.foreground.color.default}"
          },
          "hover": {
            "$type": "color",
            "$value": "{table.cell.foreground.color.hover}"
          },
          "selected": {
            "$type": "color",
            "$value": "{table.cell.foreground.color.selected}"
          }
        }
      }
    },
    "row": {
      "border": {
        "width": {
          "$type": "dimension",
          "$value": "{table.row.border.width}"
        },
        "color": {
          "default": {
            "$type": "color",
            "$value": "{table.row.border.color.default}"
          },
          "hover": {
            "$type": "color",
            "$value": "{table.row.border.color.hover}"
          },
          "selected": {
            "default": {
              "$type": "color",
              "$value": "{table.row.border.color.selected.default}"
            },
            "hover": {
              "$type": "color",
              "$value": "{table.row.border.color.selected.hover}"
            }
          }
        }
      }
    },
    "header": {
      "surface": {
        "color": {
          "$type": "color",
          "$value": "{table.header.surface.color}"
        }
      },
      "cell": {
        "padding": {
          "horizontal": {
            "short": {
              "$type": "dimension",
              "$value": "{table.header.cell.padding.horizontal.short}"
            },
            "medium": {
              "$type": "dimension",
              "$value": "{table.header.cell.padding.horizontal.medium}"
            },
            "tall": {
              "$type": "dimension",
              "$value": "{table.header.cell.padding.horizontal.tall}"
            }
          },
          "vertical": {
            "short": {
              "$type": "dimension",
              "$value": "{table.header.cell.padding.vertical.short}"
            },
            "medium": {
              "$type": "dimension",
              "$value": "{table.header.cell.padding.vertical.medium}"
            },
            "tall": {
              "$type": "dimension",
              "$value": "{table.header.cell.padding.vertical.tall}"
            }
          }
        }
      },
      "button": {
        "foreground": {
          "color": {
            "active": {
              "$type": "color",
              "$value": "{table.header.button.foreground.color.active}"
            },
            "hover": {
              "$type": "color",
              "$value": "{table.header.button.foreground.color.hover}"
            },
            "sorted": {
              "active": {
                "$type": "color",
                "$value": "{table.header.button.foreground.color.sorted.active}"
              },
              "hover": {
                "$type": "color",
                "$value": "{table.header.button.foreground.color.sorted.hover}"
              },
              "default": {
                "$type": "color",
                "$value": "{table.header.button.foreground.color.sorted.default}"
              }
            }
          }
        },
        "surface": {
          "color": {
            "active": {
              "$type": "color",
              "$value": "{table.header.button.surface.color.active}"
            },
            "hover": {
              "$type": "color",
              "$value": "{table.header.button.surface.color.hover}"
            }
          }
        }
      }
    },
    "body": {
      "surface": {
        "color": {
          "$type": "color",
          "$value": "{table.body.surface.color}"
        }
      }
    }
  }
}
