              "$type": "color",
              "$value": "{color.border.primary}",
              "group": "components",
              "$modes": {
                "default": "{color.border.primary}",
                "cds-g0": "rgba(22, 22, 22, 0.25))",
                "cds-g10": "rgba(22, 22, 22, 0.25)",
