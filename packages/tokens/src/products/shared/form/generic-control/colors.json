              "cds-g10": "{carbon.themes.g10.field01}",
              "cds-g90": "{carbon.themes.g90.field01}",
              "cds-g100": "{carbon.themes.g100.field01}"
            }
          }
        },
        "border": {
          "color": {
            "$type": "color",
            "$value": "{color.border.primary}",
            "group": "components",
            "$modes": {
              "default": "{color.border.primary}",
              "cds-g0": "transparent",
              "cds-g10": "transparent",
              "cds-g90": "transparent",
              "cds-g100": "transparent"
