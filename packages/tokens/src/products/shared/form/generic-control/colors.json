{
  "form": {
    "control": {
      "base": {
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{color.foreground.strong}",
            "group": "components"
          }
        },
        "surface": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{color.surface.interactive}",
              "group": "components"
            },
            "hover": {
              "$type": "color",
              "$value": "{color.surface.interactive-hover}",
              "group": "components",
              "$modes": {
                "default": "{color.surface.interactive-hover}",
                "cds-g0": "#f4f4f4",
                "cds-g10": "#ffffff",
                "cds-g90": "#393939",
                "cds-g100": "#262626"
              }
            },
            "selected": {
              "$type": "color",
              "$value": "{color.surface.interactive}",
              "group": "components",
              "$modes": {
                "default": "{color.surface.interactive}",
                "cds-g0": "{carbon.themes.white.layerSelected01}",
                "cds-g10": "{carbon.themes.g10.layerSelected01}",
                "cds-g90": "{carbon.themes.g90.layerSelected01}",
                "cds-g100": "{carbon.themes.g100.layerSelected01}"
