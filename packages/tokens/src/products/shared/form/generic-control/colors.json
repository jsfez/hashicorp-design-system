{
  "form": {
    "control": {
      "base": {
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{foreground.color.strong}",
            "group": "components"
          }
        },
        "surface": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{surface.color.interactive}",
              "group": "components"
            },
            "hover": {
              "$type": "color",
              "$value": "{surface.color.interactive-hover}",
              "group": "components"
            }
          }
        },
        "border": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{core.color.neutral-400}",
              "group": "components"
            },
            "hover": {
              "$type": "color",
              "$value": "{core.color.neutral-500}",
              "group": "components"
            }
          }
        },
        "placeholder": {
          "foreground": {
            "color": {
              "$type": "color",
              "$value": "{foreground.color.faint}",
              "group": "components"
            }
          }
        }
      },
      "checked": {
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{foreground.color.high-contrast}",
            "group": "components"
          }
        },
        "surface": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{core.color.blue-200}",
              "group": "components"
            },
            "hover": {
              "$type": "color",
              "$value": "{core.color.blue-300}",
              "group": "components"
            }
          }
        },
        "border": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{core.color.blue-300}",
              "group": "components"
            },
            "hover": {
              "$type": "color",
              "$value": "{core.color.blue-400}",
              "group": "components"
            }
          }
        }
      },
      "invalid": {
        "border": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{core.color.red-300}",
              "group": "components"
            },
            "hover": {
              "$type": "color",
              "$value": "{core.color.red-400}",
              "group": "components"
            }
          }
        }
      },
      "readonly": {
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{foreground.color.primary}",
            "group": "components"
          }
        },
        "surface": {
          "color": {
            "$type": "color",
            "$value": "{surface.color.strong}",
            "group": "components"
          }
        },
        "border": {
          "color": {
            "$type": "color",
            "$value": "{border.color.faint}",
            "group": "components"
          }
        }
      },
      "disabled": {
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{foreground.color.disabled}",
            "group": "components"
          }
        },
        "surface": {
          "color": {
            "$type": "color",
            "$value": "{surface.color.interactive-disabled}",
            "group": "components"
          }
        },
        "border": {
          "color": {
            "$type": "color",
            "$value": "{border.color.primary}",
            "group": "components"
          }
        }
      }
    }
  }
}
