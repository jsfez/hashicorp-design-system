              "$type": "color",
              "$value": "{color.palette.blue-300}",
              "group": "components",
              "$modes": {
                "default": "{color.palette.blue-300}",
                "cds-g0": "{carbon.color.gray.100}",
                "cds-g10": "{carbon.color.gray.100}",
                "cds-g90": "{carbon.color.gray.10}",
                "cds-g100": "{carbon.color.gray.10}"
              }
